<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingTop="12dp"
    android:paddingBottom="12dp"
    android:paddingStart="4dp"
    android:paddingEnd="4dp">

    <!-- Left: title + description + progress bar -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginEnd="12dp">

        <TextView
            android:id="@+id/tv_quest_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Quest Title"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary" />

        <TextView
            android:id="@+id/tv_quest_description"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Quest description"
            android:textSize="12sp"
            android:textColor="@color/text_muted"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="6dp" />

        <ProgressBar
            android:id="@+id/pb_quest"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="5dp"
            android:max="100"
            android:progress="0"
            android:progressTint="@color/cyan_primary_dark"
            android:progressBackgroundTint="#22000000" />

        <TextView
            android:id="@+id/tv_quest_progress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 / 10"
            android:textSize="11sp"
            android:textColor="@color/text_muted"
            android:layout_marginTop="3dp" />

    </LinearLayout>

    <!-- Right: XP chip or checkmark -->
    <FrameLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/tv_quest_xp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+100 XP"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/cyan_primary_dark"
            android:background="@color/cyan_surface"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp" />

        <TextView
            android:id="@+id/tv_quest_done"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✓"
            android:textSize="20sp"
            android:textColor="@color/cyan_primary_dark"
            android:textStyle="bold"
            android:visibility="gone" />

    </FrameLayout>

</LinearLayout>
