<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/surface_bg">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/cyan_primary"
        android:paddingTop="16dp"
        android:paddingBottom="20dp"
        android:paddingHorizontal="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Course Management"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/text_on_brand" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Manage all courses on the platform"
            android:textSize="13sp"
            android:textColor="@color/cyan_text_light"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <!-- Coming soon content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🚀"
            android:textSize="64sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Incoming Feature"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/text_title"
            android:layout_marginTop="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Course management will be available in the next update. Stay tuned!"
            android:textSize="14sp"
            android:textColor="@color/text_muted"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:layout_marginHorizontal="24dp" />
    </LinearLayout>
</LinearLayout>
