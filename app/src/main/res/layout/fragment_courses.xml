<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/surface_bg"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/my_courses_title"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/text_title"
        android:layout_marginBottom="16dp" />

    <ProgressBar
        android:id="@+id/progress_bar_courses"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:visibility="gone"
        android:layout_marginTop="40dp" />

    <TextView
        android:id="@+id/tv_courses_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="@string/no_enrolled_courses"
        android:textSize="14sp"
        android:textColor="@color/text_muted"
        android:visibility="gone"
        android:layout_marginTop="60dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_enrolled_courses"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

</LinearLayout>