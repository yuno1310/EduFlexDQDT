<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/admin_nav_graph"
    app:startDestination="@id/adminUsersFragment">

    <fragment
        android:id="@+id/adminUsersFragment"
        android:name="com.eduflex.android.ui.admin.AdminFragment"
        android:label="User Management" />

    <fragment
        android:id="@+id/adminCoursesFragment"
        android:name="com.eduflex.android.ui.admin.AdminCoursesFragment"
        android:label="Course Management">

        <action
            android:id="@+id/action_courses_to_lessons"
            app:destination="@id/adminLessonsFragment" />
    </fragment>

    <fragment
        android:id="@+id/adminLessonsFragment"
        android:name="com.eduflex.android.ui.admin.AdminLessonsFragment"
        android:label="Lesson Management">

        <argument
            android:name="courseId"
            app:argType="string" />
        <argument
            android:name="courseTitle"
            app:argType="string"
            android:defaultValue="Course" />
    </fragment>

    <fragment
        android:id="@+id/adminProfileFragment"
        android:name="com.eduflex.android.ui.admin.AdminProfileFragment"
        android:label="Profile" />
</navigation>
